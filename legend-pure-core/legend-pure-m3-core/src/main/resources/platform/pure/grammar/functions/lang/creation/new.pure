function <<test.Test>> {test.excludePlatform = 'Java compiled'} meta::pure::functions::lang::tests::newAtRuntime::testNewWithChildWithMismatchedReverseOneToOneProperty():Boolean[1]
{
   assertError(|^meta::pure::functions::lang::tests::newAtRuntime::MissingPropertyCar(name='Bugatti', owner= ^meta::pure::functions::lang::tests::newAtRuntime::MissingPropertyOwner(firstName='John', lastName='Roe', car=^meta::pure::functions::lang::tests::newAtRuntime::MissingPropertyCar(name='Audi'))),
      'Error instantiating the type \'MissingPropertyOwner\'. The property \'car\' has a multiplicity range of [1] when the given list has a cardinality equal to 2'
   );
}


