}

function <<test.Test>> meta::pure::functions::lang::tests::newInferenceAtRuntime::testDeeperEvenMoreUsingClassFunction():Boolean[1]
{
   let m = ^meta::pure::functions::lang::tests::newInferenceAtRuntime::M<String,Integer>(vals = ^meta::pure::functions::lang::tests::newInferenceAtRuntime::Structure<String,Integer>(a='eee', b=2)).put('rr',55);
   assert($m.vals->size() == 2);
}

function <<test.Test>> meta::pure::functions::lang::tests::newInferenceAtRuntime::testUsingLet():Boolean[1]
