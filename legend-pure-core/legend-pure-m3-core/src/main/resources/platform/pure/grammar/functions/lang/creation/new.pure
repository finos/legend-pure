function <<test.Test>> {test.excludePlatform = 'Java compiled'} meta::pure::functions::lang::tests::newAtRuntime::testNewWithMissingOneToOneProperty():Boolean[1]
{
   assertError(|^meta::pure::functions::lang::tests::newAtRuntime::MissingPropertyOwner(firstName='John', lastName='Roe'),
      'Error instantiating class \'MissingPropertyOwner\'.  The following properties have multiplicity violations: \'car\' requires 1 value, got 0'
   );
}

