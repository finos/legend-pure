// Pure-native tests for the executeInDb relational native function.
//
// Ported from the original JUnit `AbstractTestPureDBFunction.java`. They
// target DuckDB because DuckDB is the only backend wired across both
// stacks today; assertions about *which* backends each stack supports
// are runtime-specific and live in each stack's integration suite
// rather than here.

import meta::external::store::relational::runtime::*;
import meta::relational::runtime::*;
import meta::relational::metamodel::execute::*;

// Ported from `testExecuteInb_DuckDB_HugeInt` in
// `AbstractTestPureDBFunction.java:170`. DuckDB implicitly widens
// integer-sum results to HUGEINT; this verifies the Rust native demotes
// HUGEINT back into Pure's Integer when the value fits in i64.
function <<test.Test>> {test.excludePlatform = 'Java compiled'}
meta::relational::tests::testExecuteInDbHugeInt(): Boolean[1]
{
   let db = ^TestDatabaseConnection(type = DatabaseType.DuckDB);
   let res = executeInDb('select 1+1', $db, 0, 1000);
   assertEquals(2, $res.rows->at(0).values->at(0));
}

// Trivial column-aliased projection — locks the columnNames slot.
function <<test.Test>> {test.excludePlatform = 'Java compiled'}
meta::relational::tests::testExecuteInDbExposesColumnName(): Boolean[1]
{
   let db = ^TestDatabaseConnection(type = DatabaseType.DuckDB);
   let res = executeInDb('select 1 as alpha', $db, 0, 1000);
   assertEquals('alpha', $res.columnNames->at(0));
}

// VARCHAR round-trip: literal 'hello' must surface as Pure String.
function <<test.Test>> {test.excludePlatform = 'Java compiled'}
meta::relational::tests::testExecuteInDbVarcharRoundtrip(): Boolean[1]
{
   let db = ^TestDatabaseConnection(type = DatabaseType.DuckDB);
   let res = executeInDb('select \'hello\' as s', $db, 0, 1000);
   assertEquals('hello', $res.rows->at(0).values->at(0));
}
