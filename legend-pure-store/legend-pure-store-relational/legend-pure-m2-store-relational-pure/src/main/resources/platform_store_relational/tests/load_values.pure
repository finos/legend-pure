// Pure-native tests for loadValuesToDbTable.
//
// Uses the ###Relational DSL to declare a real Database/Schema/Table
// chain — the populated heap rows are what the native consumes when
// it reads `Table.name`.

###Pure
import meta::external::store::relational::runtime::*;
import meta::relational::runtime::*;
import meta::relational::metamodel::*;
import meta::relational::metamodel::execute::*;
import meta::relational::metamodel::relation::*;
import meta::relational::metamodel::datatype::*;

function <<access.private>> meta::relational::tests::table():Table[1]
{
   let schema = ^Schema(database = ^Database(name = 'db'), name = 'main');
   ^Table(schema = $schema, name = 'lv', columns = [
        ^Column(name = 'a', type = ^meta::relational::metamodel::datatype::Integer()),
        ^Column(name = 'b', type = ^Varchar(size = 50))
    ]
   );
}

// Insert two rows via loadValuesToDbTable and verify the count.
function <<test.Test>>
meta::relational::tests::testLoadValuesToDbTableInsertsRows(): Boolean[1]
{
   let db = ^TestDatabaseConnection(type = DatabaseType.DuckDB);
   executeInDb('CREATE TABLE lv(a INTEGER, b VARCHAR)', $db, 0, 1000);

   let row1 = ^List<Any>(values = [1, 'foo']);
   let row2 = ^List<Any>(values = [2, 'bar']);
   let outer = ^List<List<Any>>(values = [$row1, $row2]);
   let tbl = meta::relational::tests::table();
   loadValuesToDbTable($outer, $tbl, $db);

   let rs = executeInDb('SELECT count(*) FROM lv', $db, 0, 1000);
   let ok = assertEquals(2, $rs.rows->at(0).values->at(0));
   executeInDb('DROP TABLE lv', $db, 0, 1000);
   $ok;
}
